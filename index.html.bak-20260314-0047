
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>灵枢 LING SHU Pro</title>
    <link rel="manifest" href="./manifest.json">
    <link rel="stylesheet" href="./style.css">
    <!-- 保留 CDN 库 -->
    <!-- <script src="https://cdn.jsdelivr.net/npm/astronomy-engine@2.1.19/astronomy.browser.min.js"></script> -->
    <script src="./libs/astronomy.browser.min.js"></script>
</head>
<body>

    <div id="app-container">
        <!-- 顶部控制栏 -->
        <div class="control-header">
            <!-- 左侧：GPS -->
            <div class="gps-status" id="gps-indicator" title="点击复制盘面信息">
                <div class="gps-dot"></div>
                <div class="gps-info">
                    <span id="gps-coords">LOCATING...</span>
                    <span id="gps-accuracy" class="gps-sub"></span>
                </div>
            </div>

            <!-- 中间：品牌名 (新位置) -->
            <div class="brand-title-top" id="brand-title-top" style="cursor: pointer;" title="点击切换主题">
                <span>靈</span>
                <span>樞</span>
            </div>

            <!-- 右侧：操作按钮 -->
            <div class="action-group">
                <button class="icon-btn" id="btn-reset-now" title="复位至此刻">
                    <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8Z"/></svg>
                </button>
                <button class="icon-btn" id="btn-settings" title="设置">
                    <svg viewBox="0 0 24 24"><path fill="currentColor" d="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,13L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z"/></svg>
                </button>
            </div>
        </div>

        <!-- 仪表盘 (HUD) -->
        <header class="dashboard-header">
            <!-- 左: 罗盘 -->
            <div class="hud-left-compass">
                <div class="compass-widget">
                    <!-- 新增正北指向标 -->
                    <div class="cw-heading-marker"></div>
                    <div class="cw-cross-v"></div>
                    <div class="cw-cross-h"></div>
                    <div class="cw-ring" id="cw-ring"></div>
                    <div class="cw-level-area"><div class="cw-level-dot" id="level-dot"></div></div>
                </div>
                <div class="degree-display">
                    <span id="deg-num">--</span>° <span id="dir-txt">--</span>
                </div>
                
                <!-- 中轴：移动到这里，作为左侧容器的子元素，锚定到右边缘 -->
                <div class="hud-center-pivot" id="term-pivot">
                    <!-- JS 填充 -->
                    <span>--</span>
                    <span>--</span>
                </div>
            </div>

            <!-- 右: 时间与干支 -->
            <div class="hud-right-time">
                <!-- 真太阳时 + 节气时间 -->
                <div class="time-group">
                    <div class="ts-row">
                        <div class="ts-time" id="true-solar-display">00:00:00</div>
                        <div class="term-info-box" id="term-info">
                            <!-- JS 填充 -->
                        </div>
                    </div>
                    
                    <div class="legal-row">
                        <span id="time-display">00:00:00</span>
                        <span id="time-delta" class="delta-info">Δ --m</span>
                        <span id="pentad-display" class="pentad-info"></span> 
                    </div>
                </div>
                <div class="gz-group" id="gz-container">
                    <!-- JS 生成 -->
                </div>
            </div>
        </header>

        <!-- 主内容区 (日历) -->
        <main class="main-content">
            <div class="cal-container">
                <!-- 移除背景水印 -->
                
                <div class="cal-header-row">
                    <!-- 左侧：公历年月显示 + 农历 + 彝历 -->
                    <div class="cal-title-group">
                        <span id="cal-title-year-month">2024年01月</span>
                    </div>
                    
                    <!-- 右侧：步进控制器 -->
                    <div class="stepper-group">
                        <button class="icon-btn tiny" id="btn-prev"><svg viewBox="0 0 24 24"><path fill="currentColor" d="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z"/></svg></button>
                        <div class="step-wrapper">
                            <select id="step-selector" class="step-select">
                                <option value="1m">1 分钟</option>
                                <option value="10m">10 分钟</option>
                                <option value="1h" selected>1 小时</option>
                                <option value="2h">1 时辰</option>
                                <option value="1d">1 日</option>
                                <option value="1M">1 月</option>
                                <option value="1y">1 年</option>
                            </select>
                        </div>
                        <button class="icon-btn tiny" id="btn-next"><svg viewBox="0 0 24 24"><path fill="currentColor" d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z"/></svg></button>
                    </div>
                </div>
                
                <div class="cal-week-head">
                    <div>日</div><div>一</div><div>二</div><div>三</div><div>四</div><div>五</div><div>六</div>
                </div>
                <!-- 日历网格 -->
                <div class="cal-grid" id="cal-grid"></div>
            </div>

            <!-- 天文三系统数据 -->
            <div class="astro-data-box" id="astro-box">
                <div class="astro-header-labels">
                    <div class="ah-col icon-col"></div>
                    <div class="ah-col">回归(气)</div>
                    <div class="ah-col wide">宿度(J2000)</div>
                    <div class="ah-col mini">重叠</div>
                    <div class="ah-col">恒星(Lahiri) <span id="ayanamsa-val" class="header-ayan">--</span></div>
                    <div class="ah-col extra-slot"></div>
                </div>
                <!-- 太阳行 -->
                <div class="astro-row compact">
                    <div class="astro-label sun"></div>
                    <div id="sun-trop" class="astro-cell">--</div>
                    <div id="sun-mans" class="astro-cell wide">--</div>
                    <div id="sun-ov" class="astro-cell mini">--</div>
                    <div id="sun-sid" class="astro-cell">--</div>
                    <div class="astro-cell extra-slot"></div>
                </div>
                <!-- 月亮行 -->
                <div class="astro-row compact">
                    <div class="astro-label moon"></div>
                    <div id="moon-trop" class="astro-cell">--</div>
                    <div id="moon-mans" class="astro-cell wide">--</div>
                    <div id="moon-ov" class="astro-cell mini">--</div>
                    <div id="moon-sid" class="astro-cell">--</div>
                    <div class="astro-cell extra-slot"></div>
                </div>
            </div>

            <!-- 吉凶宿值面板 -->
            <div class="luck-data-box" id="luck-box">
                <div class="luck-row">
                    <!-- 左侧：基础值日数据 -->
                    <div class="luck-section-left">
                        <!-- 三合宿 -->
                        <div class="luck-item-group">
                            <span class="luck-label">三合宿</span>
                            <span class="luck-value main" id="luck-xiu">--</span>
                        </div>
                        
                        <!-- 细分隔 -->
                        <div class="luck-sub-divider"></div>

                        <!-- 农历宿 -->
                        <div class="luck-item-group">
                            <span class="luck-label">农历宿</span>
                            <span class="luck-value main" id="luck-lunar-xiu">--</span>
                        </div>
                    </div>
                    
                    <!-- 垂直分割线 -->
                    <div class="luck-divider"></div>
                    
                    <!-- 右侧：神煞动态容器 -->
                    <div class="luck-section-right" id="luck-omens">
                        <!-- 动态生成的标签将放在这里 -->
                    </div>
                </div>
            </div>

            <!-- 新增：月亮空亡监测栏 (VOC) -->
            <div class="voc-monitor-box" id="voc-box">
                <div class="voc-header">
                    <span id="voc-status-icon">○</span>
                    <span id="voc-status-text">检测中...</span>
                    <span class="voc-toggle-arrow">▼</span>
                </div>
                <div class="voc-details hidden" id="voc-details">
                    <div class="voc-rule-toggle">
                        <label><input type="radio" name="voc-rule" value="7" checked> 古典7星</label>
                        <label><input type="radio" name="voc-rule" value="10"> 现代10星</label>
                    </div>
                    <div class="voc-aspect-list" id="voc-aspect-list">
                        <!-- JS generated list -->
                    </div>
                </div>
            </div>

            <!-- 新增：古典星象详情栏 (Astro Details) -->
            <div class="voc-monitor-box" id="astro-details-box" style="margin-top: 8px;">
                <div class="voc-header" id="astro-header">
                    <span id="astro-status-icon">♃</span>
                    <span id="astro-status-text">古典星象详情</span>
                    <span class="voc-toggle-arrow" id="astro-toggle-arrow">▼</span>
                </div>
                <div class="voc-details hidden" id="astro-details">
                    <div class="astro-section" style="margin-bottom: 12px;">
                        <div class="astro-section-title" style="color: var(--text-sub); font-size: 0.85em; margin-bottom: 4px;">当前古典行星时</div>
                        <div id="planetary-hour-info" class="astro-info-text" style="color: var(--text-main); font-weight: 600;">加载中...</div>
                    </div>
                    <div class="astro-section" style="margin-bottom: 12px;">
                        <div class="astro-section-title" style="color: var(--text-sub); font-size: 0.85em; margin-bottom: 4px;">行星逆行状态</div>
                        <div id="retrograde-info" class="astro-info-text" style="color: var(--text-main);">加载中...</div>
                    </div>
                    <div class="astro-section" style="margin-bottom: 12px;">
                        <div class="astro-section-title" style="color: var(--text-sub); font-size: 0.85em; margin-bottom: 4px;">下一次本地可见日月食</div>
                        <div id="eclipse-info" class="astro-info-text" style="color: var(--text-main);">加载中...</div>
                    </div>
                    <div class="astro-section" style="text-align: center; margin-top: 12px; border-top: 1px solid var(--border-color); padding-top: 12px;">
                        <button id="btn-view-horoscope" class="btn-primary" style="width: 100%; padding: 8px; font-size: 0.9em; background: var(--bg-panel); border: 1px solid var(--border-color); color: var(--text-main); border-radius: 4px; cursor: pointer;">查看当前星盘 (Regiomontanus)</button>
                    </div>
                </div>
            </div>
            
            <!-- 星盘弹窗 -->
            <div id="horoscope-modal" class="modal hidden">
                <div class="modal-content" style="max-width: 800px; width: 98%; max-height: 95vh; overflow-y: auto; padding: 12px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border-color); padding-bottom: 8px; margin-bottom: 12px;">
                        <h3 style="margin: 0; color: var(--text-main); font-size: 1.1em;">当前星盘 (Regiomontanus)</h3>
                        <button id="btn-toggle-radix" class="btn-outline" style="padding: 4px 8px; font-size: 0.8em; width: auto;">设置本命盘 (外圈)</button>
                    </div>
                    
                    <!-- 本命盘设置面板 (默认隐藏) -->
                    <div id="radix-settings-panel" class="hidden" style="background: var(--bg-panel); padding: 12px; border: 1px solid var(--border-color); border-radius: 4px; margin-bottom: 12px; font-size: 0.85em;">
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px;">
                            <div class="form-group" style="margin-bottom: 0;">
                                <label>日期</label>
                                <input type="date" id="radix-date" class="input-dark" value="1994-11-22" style="padding: 6px;">
                            </div>
                            <div class="form-group" style="margin-bottom: 0;">
                                <label>时间</label>
                                <input type="time" id="radix-time" class="input-dark" value="06:28" style="padding: 6px;">
                            </div>
                        </div>
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 8px;">
                            <div class="form-group" style="margin-bottom: 0;">
                                <label>经度 (E)</label>
                                <input type="number" id="radix-lon" class="input-dark" value="109.58519904" step="0.00000001" style="padding: 6px;">
                            </div>
                            <div class="form-group" style="margin-bottom: 0;">
                                <label>纬度 (N)</label>
                                <input type="number" id="radix-lat" class="input-dark" value="31.32885239" step="0.00000001" style="padding: 6px;">
                            </div>
                        </div>
                        <div style="display: flex; gap: 8px;">
                            <button id="btn-apply-radix" class="btn-primary" style="padding: 6px; font-size: 0.9em;">应用外圈</button>
                            <button id="btn-clear-radix" class="btn-outline" style="padding: 6px; font-size: 0.9em;">清除外圈</button>
                        </div>
                    </div>

                    <!-- 响应式布局容器 -->
                    <div class="horoscope-layout" style="display: flex; flex-direction: column; gap: 12px;">
                        <!-- 缩放控制 -->
                        <div style="display: flex; align-items: center; justify-content: center; gap: 16px; font-size: 0.85em; color: var(--text-secondary);">
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span>缩放星盘:</span>
                                <input type="range" id="chart-zoom-slider" min="0.5" max="2" step="0.1" value="1" style="width: 150px;">
                            </div>
                            <label style="display: flex; align-items: center; gap: 4px; cursor: pointer;">
                                <input type="checkbox" id="chart-show-outer" checked> 显示三王星
                            </label>
                        </div>
                        <!-- 图形星盘容器 -->
                        <div id="astro-chart-container" style="width: 100%; aspect-ratio: 1/1; background: #fff; border-radius: 8px; overflow: auto; border: 1px solid var(--border-color); position: relative;"></div>
                        
                        <!-- 数据表格容器 -->
                        <div id="horoscope-data-container" style="font-size: 0.8em; line-height: 1.4;">
                            <!-- Data will be injected here -->
                        </div>
                    </div>

                    <div class="form-actions" style="margin-top: 16px;">
                        <button id="btn-close-horoscope" class="btn-outline" style="width: 100%;">关闭</button>
                    </div>
                </div>
            </div>
            
            <div class="detail-row">
                <div class="detail-item">
                    <span class="d-label">月相</span>
                    <span id="moon-phase" class="d-val">--</span>
                    <span id="moon-illum" class="d-sub">--%</span>
                </div>
                <div class="detail-item">
                    <span class="d-label">角距</span>
                    <span id="moon-angle" class="d-val">--°</span>
                </div>
                <div class="detail-item">
                    <span class="d-label">模式</span>
                    <span id="mode-display" class="d-val">--</span>
                </div>
            </div>
        </main>

        <!-- 设置弹窗 -->
        <div id="settings-modal" class="modal hidden">
            <div class="modal-content">
                <h3>高级设定</h3>
                <div class="form-group"><label>指定时间</label><input type="datetime-local" id="set-time" class="input-dark"></div>
                
                <!-- 新增：城市选择器 -->
                <div class="form-group">
                    <label>地点预设 (中国)</label>
                    <div class="geo-select-group">
                        <select id="sel-prov" class="input-dark"><option value="">- 省 -</option></select>
                        <select id="sel-city" class="input-dark"><option value="">- 市 -</option></select>
                        <select id="sel-dist" class="input-dark"><option value="">- 区 -</option></select>
                    </div>
                </div>

                <div class="form-group"><label>经度</label><input type="number" id="set-lon" class="input-dark" step="0.0001"></div>
                <div class="form-group"><label>纬度</label><input type="number" id="set-lat" class="input-dark" step="0.0001"></div>
                <div class="form-actions">
                    <button id="btn-cancel" class="btn-outline">关闭</button>
                    <button id="btn-confirm" class="btn-primary">应用</button>
                </div>
            </div>
        </div>
    </div>
    
    <!-- 直接引入主程序逻辑 -->
    <script type="module" src="./js/app.js"></script>
</body>
</html>
